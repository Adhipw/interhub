sequenceDiagram
    autonumber
    actor UserActor as User (Mahasiswa/Mentor)
    participant Frontend
    participant Backend
    participant DB as Database
    participant Reverb as Laravel Reverb
    participant Resend as Resend (Email)
    actor TargetActor as Target User (HR/Mahasiswa)

    UserActor->>Frontend: Perform Action (Submit Lamaran/Feedback)
    Frontend->>Backend: API Request
    Backend->>DB: Process Data & Create Notification Record
    Backend-->>Frontend: Response Success
    
    par [Realtime Push]
        Backend->>Reverb: Dispatch Notification Event
        Reverb-->>TargetActor: Broadcast Message via WebSocket
        TargetActor->>TargetActor: Show UI Toast/Notification
    and [Email Fallback]
        Backend->>Resend: Send Important Email (OTP/Accepted)
        Resend-->>TargetActor: Deliver Email Notification
    end
